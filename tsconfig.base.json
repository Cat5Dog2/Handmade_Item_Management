{
  "compilerOptions": {
    "target": "ES2022",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@handmade/shared": ["packages/shared/src/index.ts"],
      "@handmade/shared/*": ["packages/shared/src/*"]
    },
    "noEmitOnError": true
  }
}
