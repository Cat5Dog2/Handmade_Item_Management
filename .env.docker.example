# -------------------------------------------------------------
# Docker / Local development
# -------------------------------------------------------------
FIREBASE_PROJECT_ID=handmade-item-management

# Web -> API
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://api:8080

# API allowlist
APP_OWNER_EMAIL=your-login-email@example.com

# Web -> Firebase emulators
# Browser から見えるのは docker service 名ではなく localhost 側の公開ポートです。
VITE_USE_FIREBASE_EMULATORS=true
VITE_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
VITE_FIRESTORE_EMULATOR_HOST=localhost:8081
VITE_FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Firebase Web SDK public config
# 実値がある場合は置き換えてください。
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=handmade-item-management.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=handmade-item-management
VITE_FIREBASE_STORAGE_BUCKET=handmade-item-management.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# API runtime options (必要なら追加)
SIGNED_URL_EXPIRES_MINUTES=60
IMAGE_MAX_FILE_SIZE_MB=10
IMAGE_MAX_COUNT_PER_PRODUCT=10
IMAGE_DISPLAY_MAX_EDGE_PX=2000
IMAGE_THUMB_MAX_EDGE_PX=400
IMAGE_OUTPUT_FORMAT=webp
IMAGE_DISPLAY_WEBP_QUALITY=82
IMAGE_THUMB_WEBP_QUALITY=75
PRODUCT_ID_PREFIX=HM-
PRODUCT_ID_DIGITS=6
PRODUCT_COUNTER_DOCUMENT_PATH=counters/product
