# =============================================================
# ハンドメイド販売管理アプリ .env.example
# =============================================================
# このファイルは「実装時に必要になる代表的な環境変数のひな形」です。
# 実際のリポジトリでは、以下のどちらかで運用してください。
#   1) ルート .env として一元管理する
#   2) apps/web/.env.local と apps/api/.env に分割する
#
# 運用ルール:
# - 値が未設定でも動かせる箇所は、起動時に明確なエラーを出す
# - シークレットはコミットしない
# - 本番値を example に書かない
# - VITE_ プレフィックス付き変数のみフロントへ公開する
# =============================================================

# -------------------------------------------------------------
# 共通
# -------------------------------------------------------------
NODE_ENV=development
APP_NAME=handmade-sales-manager
APP_TIMEZONE=Asia/Tokyo
LOG_LEVEL=info

# -------------------------------------------------------------
# Web (React + Vite)
# Vite から参照するものは必ず VITE_ プレフィックスを付ける
# -------------------------------------------------------------
VITE_APP_NAME=ハンドメイド販売管理アプリ
VITE_APP_TIMEZONE=Asia/Tokyo

# API ベースURL
# - ローカル開発時: http://localhost:8080/api
# - 本番配信時: Firebase Hosting rewrite 前提で /api を利用
VITE_API_BASE_URL=http://localhost:8080/api

# Firebase Web SDK
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage バケット名
# 例:
# - your-project-id.firebasestorage.app
# - your-project-id.appspot.com
VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket-name

VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890

# 任意: Analytics を使わない場合は未設定でもよい
VITE_FIREBASE_MEASUREMENT_ID=

# ローカルで Firebase Emulator Suite を使う場合のみ設定する
VITE_USE_FIREBASE_EMULATORS=false
VITE_FIREBASE_AUTH_EMULATOR_HOST=
VITE_FIRESTORE_EMULATOR_HOST=
VITE_FIREBASE_STORAGE_EMULATOR_HOST=

# -------------------------------------------------------------
# API (Node.js + Express)
# -------------------------------------------------------------
PORT=8080
API_BASE_PATH=/api

# 単独利用の allowlist
# Firebase Authentication でログインできても、API ではこのメールアドレスと一致する
# ユーザーのみ許可する
APP_OWNER_EMAIL=your-login-email@example.com

# CORS 許可オリジン
# - ローカル開発時: http://localhost:5173
# - 本番時: Firebase Hosting の公開URLまたはカスタムドメイン
CORS_ORIGIN=http://localhost:5173

# -------------------------------------------------------------
# Firebase Admin / GCP
# -------------------------------------------------------------
# ローカル開発では ADC またはサービスアカウント JSON を利用する。
# Cloud Run 本番では通常、GOOGLE_APPLICATION_CREDENTIALS は不要。
GOOGLE_CLOUD_PROJECT=your-project-id
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-storage-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# 認証トークン検証
# Firebase Admin SDK で検証する前提
# ローカルで Auth Emulator を使う場合のみ設定する
FIREBASE_AUTH_EMULATOR_HOST=

# -------------------------------------------------------------
# 画像処理
# -------------------------------------------------------------
IMAGE_MAX_FILE_SIZE_MB=10
IMAGE_MAX_COUNT_PER_PRODUCT=10
IMAGE_DISPLAY_MAX_EDGE_PX=2000
IMAGE_THUMB_MAX_EDGE_PX=400
IMAGE_OUTPUT_FORMAT=webp
IMAGE_DISPLAY_WEBP_QUALITY=82
IMAGE_THUMB_WEBP_QUALITY=75

# 期限付きURL
SIGNED_URL_EXPIRES_MINUTES=60

# -------------------------------------------------------------
# 商品ID採番
# -------------------------------------------------------------
PRODUCT_ID_PREFIX=HM-
PRODUCT_ID_DIGITS=6
PRODUCT_COUNTER_DOCUMENT_PATH=counters/product

# -------------------------------------------------------------
# エミュレータ
# -------------------------------------------------------------
# アプリ側の ON/OFF 切替用フラグ
FIREBASE_USE_EMULATOR=false

# Firebase / Firestore / Storage Emulator 接続先
# 利用する場合は host:port 形式で設定する
# 例:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
FIRESTORE_EMULATOR_HOST=
FIREBASE_STORAGE_EMULATOR_HOST=

# -------------------------------------------------------------
# アプリ公開URL / API公開URL
# -------------------------------------------------------------
# ローカル開発時の既定値
APP_BASE_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8080/api

# 本番では以下のような値を設定する
# APP_BASE_URL=https://<your-hosting-domain>
# PUBLIC_API_URL=https://<your-hosting-domain>/api

# -------------------------------------------------------------
# 任意: 監視・デバッグ
# -------------------------------------------------------------
ENABLE_REQUEST_LOG=true
ENABLE_QUERY_DEBUG=false
